# ============================================================
# RepairTrack - Variables de Entorno
# ============================================================
# Copiar este archivo como .env.local y completar los valores
#
# Para obtener estos valores:
# 1. Ir a https://supabase.com → crear proyecto
# 2. Settings → API → copiar URL y anon key
# ============================================================

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

RESEND_API_KEY=re_your_api_key_here
NEXT_PUBLIC_APP_URL=http://localhost:3000
RESEND_FROM_EMAIL=noreply@tudominio.com

# Cron Jobs
CRON_SECRET=a-long-random-secret-string
